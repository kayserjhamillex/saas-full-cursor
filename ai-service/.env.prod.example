PYTHONUNBUFFERED=1
AI_LOG_LEVEL=INFO

# Seguridad de endpoints
AI_REQUIRE_API_KEY=true
AI_API_KEY=replace-with-strong-random-secret
AI_PROTECT_METRICS_ENDPOINT=true
AI_METRICS_INTERNAL_ONLY=true
AI_METRICS_ALLOWED_CIDRS=127.0.0.1/32,172.16.0.0/12,::1/128

# Limites de payload / validacion de entrada
AI_MAX_IMAGE_SIZE_BYTES=8388608
AI_MAX_REQUEST_BODY_BYTES=12582912

# Modelos y rutas
AI_CNN_MODEL_VERSION=cnn-0.1.0
AI_UNET_MODEL_VERSION=unet-0.1.0
AI_MODEL_OUTPUT_DIR=models
AI_ACTIVE_MODEL_MANIFEST_PATH=models/active_model.json
AI_TRAINING_DATASET_PATH=training/data/training_dataset.json

# Umbrales de calidad de modelo
AI_MODEL_MIN_ACCURACY=0.7
AI_MODEL_MIN_PRECISION=0.7
AI_MODEL_MIN_RECALL=0.7

# Rate limit distribuido
AI_RATE_LIMIT_REQUESTS=30
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_RATE_LIMIT_BACKEND=redis
AI_REDIS_URL=redis://redis:6379/0

# Uvicorn
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=2

# Alertas / observabilidad
AI_METRICS_URL=http://localhost:8000/metrics
AI_ALERT_MAX_ERROR_RATE=0.05
AI_ALERT_MAX_P95_MS=200
AI_ALERT_MIN_REQUESTS_FOR_ALERT=20

# Smoke / benchmark
AI_LOAD_TOTAL_REQUESTS=200
AI_LOAD_CONCURRENCY=20
AI_LOAD_MAX_P95_MS=80
AI_LOAD_MIN_THROUGHPUT_RPS=50
AI_BENCHMARK_TOTAL_REQUESTS=120
AI_BENCHMARK_CONCURRENCY=20
AI_BENCHMARK_RUNS=1
AI_BENCHMARK_WARMUP_RUNS=0
AI_BENCHMARK_MAX_P95_REGRESSION_PCT=10
AI_BENCHMARK_MAX_P99_REGRESSION_PCT=10
AI_BENCHMARK_MAX_THROUGHPUT_DROP_PCT=10
AI_BENCHMARK_ARTIFACTS_DIR=benchmarks/ci-artifacts
AI_BENCHMARK_PERSIST_ON_SUCCESS=false
