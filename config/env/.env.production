APP_ENV=production
NODE_ENV=production
JWT_SECRET=prod_replace_with_secret
API_URL=https://api.tu-dominio.com/gateway
ENABLE_TENANT_CACHE=true
TENANT_CACHE_TTL_SECONDS=45
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
EMAIL_QUEUE_CONCURRENCY=4
EMAIL_QUEUE_MAX_RETRIES=5
EMAIL_QUEUE_RETRY_DELAY_MS=600
