APP_ENV=staging
NODE_ENV=staging
JWT_SECRET=staging_replace_with_secret
API_URL=https://staging-api.tu-dominio.com/gateway
ENABLE_TENANT_CACHE=true
TENANT_CACHE_TTL_SECONDS=30
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
EMAIL_QUEUE_CONCURRENCY=2
EMAIL_QUEUE_MAX_RETRIES=3
EMAIL_QUEUE_RETRY_DELAY_MS=400
