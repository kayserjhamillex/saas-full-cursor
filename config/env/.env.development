APP_ENV=development
NODE_ENV=development
JWT_SECRET=dev_jwt_secret_change_before_prod
API_URL=http://localhost:3000/gateway
ENABLE_TENANT_CACHE=true
TENANT_CACHE_TTL_SECONDS=30
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672
EMAIL_QUEUE_CONCURRENCY=2
EMAIL_QUEUE_MAX_RETRIES=3
EMAIL_QUEUE_RETRY_DELAY_MS=400
